# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Shared secret for authenticating outbound calls to Supabase Edge Functions.
# Must match X-Bot-Secret configured in the Edge Functions.
RAILWAY_BOT_SECRET=your-secret-here

# Base URL of the Lovable/Supabase Edge Functions deployment
# Example: https://vqlesrbrrxscydvjjeux.supabase.co/functions/v1
LOVABLE_EDGE_URL=https://vqlesrbrrxscydvjjeux.supabase.co/functions/v1

# Servidor
PORT=3000

# WhatsApp - Números de gerentes autorizados para usar el Bot Central
# Formato: número completo con código de país, sin + ni espacios
# Ejemplo: 5219991234567,5219997654321
GERENTES_NUMEROS=5219991234567

# Alertas - días de inactividad antes de generar alerta
ALERT_THRESHOLD_DAYS=3
